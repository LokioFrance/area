# ─────────────────────────────────────────────────────────────────────────────
# AREA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs avant le déploiement.
# NE JAMAIS committer le fichier .env sur git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────

# Clé secrète Django — générer avec :
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme-generate-a-real-secret-key

# Passer à false en production
DJANGO_DEBUG=false

# Hosts autorisés, séparés par des virgules (ex: monserveur.com,localhost)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Sécurité / Admin ──────────────────────────────────────────────────────────

# URL secrète de la vraie interface d'administration Django (sans slash de début/fin).
# Choisir une URL difficile à deviner (ex: un token aléatoire).
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(16))"
# /admin/ est un honeypot et loggue toutes les tentatives dans honeypot.log.
DJANGO_ADMIN_URL=changeme-secret-admin-url

# ── JWT ───────────────────────────────────────────────────────────────────────

# Durée de vie du token d'accès (en minutes)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# Durée de vie du token de rafraîchissement (en jours)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Gunicorn ──────────────────────────────────────────────────────────────────

# Nombre de workers (règle : 2 × CPU + 1)
GUNICORN_WORKERS=3

# Timeout des requêtes en secondes
GUNICORN_TIMEOUT=30

# ── Docker / Réseau ───────────────────────────────────────────────────────────

# Port exposé sur l'hôte pour l'API area (le conteneur écoute sur 8000)
HOST_PORT=8001

# ── Honeypot ──────────────────────────────────────────────────────────────────

# Clé partagée pour sécuriser l'endpoint GET /api/honeypot/.
# L'UI l'envoie via l'en-tête HTTP : X-Honeypot-Key: <valeur>
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
HONEYPOT_API_KEY=changeme-honeypot-key

# ── MCP (Model Context Protocol) ──────────────────────────────────────────────

# Port interne du serveur MCP (dans le conteneur area-mcp)
MCP_PORT=9000

# Port exposé sur l'hôte pour le serveur MCP
# Claude ou tout client MCP se connecte à http://localhost:MCP_HOST_PORT/sse
MCP_HOST_PORT=9001

# Clé partagée optionnelle pour sécuriser l'accès au serveur MCP.
# Si définie, les clients MCP doivent envoyer l'en-tête : X-MCP-Key: <valeur>
# Laisser vide pour désactiver (non recommandé en production).
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=changeme-or-leave-empty
